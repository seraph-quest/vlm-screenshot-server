# Server
HOST=0.0.0.0
PORT=8088

# OpenAI-compatible VLM backend. Usually vLLM, SGLang, llama.cpp server, Ollama proxy,
# LM Studio, or any LAN endpoint that accepts /v1/chat/completions.
VLM_BASE_URL=http://gpu-host.local:8000/v1
VLM_API_KEY=
VLM_MODEL=google/gemma-4-12b-it

# Optional when using docker-compose.gpu.yml to run the backend on the same host.
# Set this to the exact Gemma 4 or quantized model ID you have access to.
GPU_MODEL_ID=google/gemma-4-12b-it
HUGGING_FACE_HUB_TOKEN=

# Request behavior
VLM_TIMEOUT_SECONDS=120
VLM_MAX_TOKENS=700
VLM_TEMPERATURE=0

# Privacy guardrails
REDACT_VISIBLE_TEXT=true
