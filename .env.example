# Wrapper API server. Current Seraph topology runs this Docker wrapper on the
# GPU host, publishes it on the LAN, and exposes it to Seraph over HTTP API.
# SSH is admin/deploy only.
HOST=0.0.0.0
PORT=8001
HOST_BIND=0.0.0.0
HOST_PORT=8001

# OpenAI-compatible VLM backend. Usually llama.cpp server, vLLM, SGLang,
# LM Studio, or another OpenAI-compatible vision endpoint. In the current
# topology this backend runs on the GPU host and is reached from the wrapper
# container through the GPU host LAN address.
VLM_BASE_URL=http://192.168.1.26:8000/v1
VLM_ALLOW_DOCKER_LOCALHOST=false
VLM_API_KEY=
VLM_MODEL=unsloth/gemma-4-31B-it-qat-GGUF-schema-43cc1aeb

# Pinned CUDA llama.cpp Gemma backend used by docker-compose.gpu.yml.
# The refreshed 31B QAT build is primary; point these at the matching 26B
# revision directory/files only when the 31B controller preflight does not fit.
GPU_LLAMA_IMAGE=ghcr.io/ggml-org/llama.cpp:server-cuda@sha256:8d1e8ddc42585632d7bd625c2285eba891ed2ed4428e9eda25ca71ce2f6cce27
GPU_MODEL_DIR=/home/pawel/models/gemma4-schema/31b-43cc1aeb31adf47ec06a854507ce552cd9862e6f
GPU_MODEL_FILE=gemma-4-31B-it-qat-UD-Q4_K_XL.gguf
GPU_MMPROJ_FILE=mmproj-BF16.gguf
GPU_MTP_DRAFTER_FILE=mtp-gemma-4-31B-it.gguf
GPU_MODEL_ALIAS=unsloth/gemma-4-31B-it-qat-GGUF-schema-43cc1aeb
GPU_MODEL_CTX_SIZE=32768
GPU_MODEL_LAYERS=999

# Request behavior
VLM_TIMEOUT_SECONDS=180
VLM_MAX_TOKENS=700
VLM_TEMPERATURE=0
QUEUE_MAX_SIZE=8
QUEUE_WORKERS=1
QUEUE_BACKGROUND_WORKERS=1
QUEUE_ADMIT_TIMEOUT_SECONDS=1
QUEUE_RESULT_TIMEOUT_SECONDS=600

# Privacy guardrails
REDACT_VISIBLE_TEXT=true

# Optional OpenAI-compatible chat proxy for Seraph local LLM routing.
# Keep disabled unless this wrapper is bound to localhost/private LAN and Seraph
# sends the same key as LOCAL_LLM_API_KEY.
CHAT_PROXY_ENABLED=false
CHAT_PROXY_API_KEY=change-me-local-only
