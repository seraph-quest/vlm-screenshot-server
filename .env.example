# Wrapper API server. For the Mac-native Seraph setup, run the wrapper on localhost:8000.
HOST=127.0.0.1
PORT=8000

# OpenAI-compatible VLM backend. Usually llama.cpp server, vLLM, SGLang,
# LM Studio, or another OpenAI-compatible vision endpoint on the GPU host.
VLM_BASE_URL=http://192.168.1.26:8000/v1
VLM_API_KEY=
VLM_MODEL=unsloth/gemma-4-26B-A4B-it-qat-GGUF

# Optional when using docker-compose.gpu.yml to run the backend on the same host.
GPU_MODEL_ID=unsloth/gemma-4-26B-A4B-it-qat-GGUF
HUGGING_FACE_HUB_TOKEN=

# Request behavior
VLM_TIMEOUT_SECONDS=180
VLM_MAX_TOKENS=700
VLM_TEMPERATURE=0
QUEUE_MAX_SIZE=8
QUEUE_WORKERS=2
QUEUE_BACKGROUND_WORKERS=1
QUEUE_ADMIT_TIMEOUT_SECONDS=1
QUEUE_RESULT_TIMEOUT_SECONDS=600

# Privacy guardrails
REDACT_VISIBLE_TEXT=true

# Optional OpenAI-compatible chat proxy for Seraph local LLM routing.
# Keep disabled unless this wrapper is bound to localhost/private LAN and Seraph
# sends the same key as LOCAL_LLM_API_KEY.
CHAT_PROXY_ENABLED=false
CHAT_PROXY_API_KEY=change-me-local-only
